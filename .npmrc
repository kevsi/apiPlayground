# .npmrc at workspace root (apiPlayground-main/)
# Required so Turbopack (Next.js 16 default bundler) can resolve
# `next` from reqy-web/. pnpm's default symlink-based node_modules confuses
# Turbopack, producing "couldn't find the Next.js package".
#
# `shamefully-hoist=true` is the recommended option for pnpm workspaces:
# it hoists all transitive deps to a flat root node_modules/, so Turbopack's
# resolver finds packages exactly where it expects them.
shamefully-hoist=true
