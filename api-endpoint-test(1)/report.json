п»ҝ[{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\app\\ai-insights\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'useEffect' is defined but never used.","line":3,"column":10,"messageId":"unusedVar","endLine":3,"endColumn":19,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"useEffect"},"fix":{"range":[23,33],"text":""},"desc":"Remove unused variable \"useEffect\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'HttpMethod' is defined but never used.","line":18,"column":32,"messageId":"unusedVar","endLine":18,"endColumn":42,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"HttpMethod"},"fix":{"range":[651,668],"text":""},"desc":"Remove unused variable \"HttpMethod\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'saveAIProvider' is defined but never used.","line":19,"column":50,"messageId":"unusedVar","endLine":19,"endColumn":64,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"saveAIProvider"},"fix":{"range":[751,767],"text":""},"desc":"Remove unused variable \"saveAIProvider\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'buildCurlSnippet' is assigned a value but never used.","line":211,"column":9,"messageId":"unusedVar","endLine":211,"endColumn":25},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'buildFetchSnippet' is assigned a value but never used.","line":222,"column":9,"messageId":"unusedVar","endLine":222,"endColumn":26},{"ruleId":"no-empty","severity":1,"message":"Empty block statement.","line":271,"column":13,"messageId":"unexpected","endLine":271,"endColumn":15,"suggestions":[{"messageId":"suggestComment","data":{"type":"block"},"fix":{"range":[11017,11017],"text":" /* empty */ "},"desc":"Add comment inside empty block statement."}]},{"ruleId":"no-empty","severity":1,"message":"Empty block statement.","line":338,"column":15,"messageId":"unexpected","endLine":338,"endColumn":17,"suggestions":[{"messageId":"suggestComment","data":{"type":"block"},"fix":{"range":[13370,13370],"text":" /* empty */ "},"desc":"Add comment inside empty block statement."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":448,"column":125,"messageId":"unexpectedAny","endLine":448,"endColumn":128,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[18814,18817],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[18814,18817],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":450,"column":137,"messageId":"unexpectedAny","endLine":450,"endColumn":140,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[19012,19015],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[19012,19015],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"no-empty","severity":1,"message":"Empty block statement.","line":452,"column":33,"messageId":"unexpected","endLine":452,"endColumn":35,"suggestions":[{"messageId":"suggestComment","data":{"type":"block"},"fix":{"range":[19078,19078],"text":" /* empty */ "},"desc":"Add comment inside empty block statement."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":10,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\"\n\nimport { useEffect, useMemo, useState } from \"react\"\nimport { Sparkles, Loader2, Send, Plus, RefreshCw, Users, Bell, ChevronsUpDown, Check } from \"lucide-react\"\nimport { Button } from \"@/components/ui/button\"\nimport { Input } from \"@/components/ui/input\"\nimport { ApiSidebar } from \"@/components/api-sidebar\"\nimport { useSidebar } from \"@/contexts/sidebar-context\"\nimport { EnvironmentSelector } from \"@/components/environment-selector\"\nimport {\n  DropdownMenu,\n  DropdownMenuTrigger,\n  DropdownMenuContent,\n  DropdownMenuItem,\n  DropdownMenuLabel,\n  DropdownMenuSeparator,\n} from \"@/components/ui/dropdown-menu\"\nimport { useRequestStore, type HttpMethod } from \"@/hooks/use-request-store\"\nimport { loadApiKey, saveApiKey, loadAIProvider, saveAIProvider, loadOllamaConfig, type AIProvider } from \"@/hooks/use-projects-store\"\nimport { toast } from \"@/hooks/use-toast\"\nimport { cn } from \"@/lib/utils\"\n\nconst PROVIDERS: { value: AIProvider; label: string }[] = [\n  { value: \"openai\", label: \"OpenAI\" },\n  { value: \"openrouter\", label: \"OpenRouter\" },\n  { value: \"anthropic\", label: \"Anthropic\" },\n  { value: \"gemini\", label: \"Gemini\" },\n  { value: \"ollama\", label: \"Ollama\" },\n]\n\nconst SUGGESTIONS = [\n  \"Donne-moi une recommandation de test API pour ce projet.\",\n  \"Rв”ңвҢҗsume les routes principales de ce projet.\",\n  \"Propose une requв”ңВ¬te de test basв”ңвҢҗe sur l'historique rв”ңвҢҗcent.\",\n  \"Aide-moi в”ңГЎ corriger ce endpoint si nв”ңвҢҗcessaire.\",\n]\n\nconst STYLE_TAGS = [\"Rapide\", \"Prв”ңвҢҗcis\", \"Concis\", \"Exploratoire\", \"Debug\"]\n\ninterface ChatMessage {\n  role: \"user\" | \"assistant\"\n  content: string\n}\n\nexport default function AiInsightsPage() {\n  const { isCollapsed, toggleSidebar } = useSidebar()\n  const { history, projects, selectedProjectId, setSelectedProject, notifications, addNotification, markNotificationRead, clearNotifications, requestSystemNotificationPermission, systemNotificationPermission } = useRequestStore()\n  const selectedProject = projects.find((project) => project.id === selectedProjectId)\n\n  const [provider, setProvider] = useState<AIProvider>(() => loadAIProvider())\n  const [apiKey, setApiKey] = useState(() => loadApiKey(loadAIProvider()))\n  \n  const isProviderConfigured = provider === \"ollama\" || (loadAIProvider() === provider && apiKey.trim().length > 0)\n  \n  const [sendStatus, setSendStatus] = useState<string | null>(null)\n\n  const getOllamaConfig = () => {\n    const config = loadOllamaConfig()\n    return {\n      host: config.host || \"127.0.0.1\",\n      port: config.port || 11434,\n      model: config.model || \"llama2\",\n    }\n  }\n  const [query, setQuery] = useState(\"\")\n  const [messages, setMessages] = useState<ChatMessage[]>([])\n  const [loading, setLoading] = useState(false)\n  const [selectedHistoryRequestId, setSelectedHistoryRequestId] = useState<string | null>(null)\n  const [generatedTests, setGeneratedTests] = useState<{\n    jest: string\n    fetch: string\n    curl: string\n    raw: string\n  } | null>(null)\n  const [generatingTests, setGeneratingTests] = useState(false)\n\n  const currentHistory = useMemo(() => history.slice(0, 5), [history])\n  const recentHistory = useMemo(() => history.slice(0, 8), [history])\n\n  const selectedHistoryRequest = useMemo(() => {\n    if (recentHistory.length === 0) return null\n    if (!selectedHistoryRequestId) return recentHistory[0]\n    return recentHistory.find((item) => item.id === selectedHistoryRequestId) ?? recentHistory[0]\n  }, [recentHistory, selectedHistoryRequestId])\n\n  const parseGeneratedTests = (content: string) => {\n    const jsonText = extractJsonBlock(content)\n    try {\n      return JSON.parse(jsonText)\n    } catch {\n      return null\n    }\n  }\n\n  const handleGenerateTests = async () => {\n    if (!selectedHistoryRequest) {\n      toast({ title: \"Sв”ңвҢҗlectionne une requв”ңВ¬te pour gв”ңвҢҗnв”ңвҢҗrer des tests\", variant: \"destructive\" })\n      return\n    }\n\n    if (provider !== \"ollama\" && !apiKey.trim()) {\n      toast({ title: \"Clв”ңвҢҗ API requise pour le provider choisi\", variant: \"destructive\" })\n      return\n    }\n\n    setGeneratingTests(true)\n    setGeneratedTests(null)\n\n    try {\n      if (provider !== \"ollama\") saveApiKey(provider, apiKey)\n\n      const prompt = `Gв”ңвҢҗnв”ңВҝre trois extraits de code pour tester cette requв”ңВ¬te API et sa rв”ңвҢҗponse. Retourne uniquement un JSON valide avec les champs : jest, fetch, curl. Utilise ce format exact : { \"jest\": string, \"fetch\": string, \"curl\": string }.`\n      const ollamaConfig = provider === \"ollama\" ? getOllamaConfig() : null\n      const payload = {\n        provider,\n        apiKey,\n        model:\n          provider === \"anthropic\"\n            ? \"claude-sonnet-4-20250514\"\n            : provider === \"openai\"\n            ? \"gpt-3.5-turbo\"\n            : provider === \"openrouter\"\n            ? \"openai/gpt-5.2\"\n            : provider === \"gemini\"\n            ? \"gemini-2.0-flash\"\n            : ollamaConfig?.model || \"llama2\",\n        host: ollamaConfig?.host,\n        port: ollamaConfig?.port,\n        system: `${systemInstructions}\\n\nVoici la requв”ңВ¬te sв”ңвҢҗlectionnв”ңвҢҗe :\\n- method: ${selectedHistoryRequest.method}\\n- url: ${selectedHistoryRequest.endpoint || selectedHistoryRequest.url}\\n- headers: ${JSON.stringify(selectedHistoryRequest.headers || {})}\\n- body: ${selectedHistoryRequest.body || \"\"}\\n- responseStatus: ${selectedHistoryRequest.responseStatus ?? \"inconnu\"}\\n- responseTime: ${selectedHistoryRequest.responseTime ?? \"inconnu\"} ms\\n\\nGв”ңвҢҗnв”ңВҝre un test Jest avec supertest, un exemple Fetch natif et une commande cURL. Rв”ңвҢҗponds uniquement avec du JSON.`,\n        message: prompt,\n      }\n\n      const response = await fetch(\"/api/proxy-ai\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(payload),\n      })\n\n      const rawText = await response.text()\n      let data: { error?: string | { message?: string }; content?: string; jest?: string; fetch?: string; curl?: string } = {}\n      try {\n        data = JSON.parse(rawText)\n      } catch {\n        data = { content: rawText }\n      }\n\n      if (!response.ok) {\n        const errorMsg = typeof data.error === \"object\" ? data.error?.message : data.error;\n        toast({ title: errorMsg ?? rawText ?? \"Erreur IA\", variant: \"destructive\" })\n        return\n      }\n\n      const content = typeof data.content === \"string\" ? data.content : rawText\n      const parsed = parseGeneratedTests(content) ?? (typeof data === \"object\" && (data.jest || data.fetch || data.curl) ? data : null)\n\n      if (parsed && (parsed.jest || parsed.fetch || parsed.curl)) {\n        setGeneratedTests({\n          jest: parsed.jest ?? \"\",\n          fetch: parsed.fetch ?? \"\",\n          curl: parsed.curl ?? \"\",\n          raw: content,\n        })\n      } else {\n        setGeneratedTests({ jest: \"\", fetch: \"\", curl: \"\", raw: content })\n      }\n    } catch (error) {\n      toast({ title: `Erreur IA : ${String(error)}`, variant: \"destructive\" })\n    } finally {\n      setGeneratingTests(false)\n    }\n  }\n\n  const routeSummary = useMemo(() => {\n    if (!selectedProject) {\n      if (projects.length === 0) return \"Aucun projet disponible. Ajoute un projet dans Mes Projets.\"\n      return \"Sв”ңвҢҗlectionne un projet actif pour voir les routes disponibles.\"\n    }\n    const routes = selectedProject.routes.slice(0, 8)\n    if (routes.length === 0) return \"Aucun endpoint dв”ңвҢҗtectв”ңвҢҗ\"\n    return routes.map((route) => `${route.method} ${route.path}`).join(\"\\n\")\n  }, [selectedProject, projects.length])\n\n  const requestSummary = useMemo(() => {\n    if (currentHistory.length === 0) return \"Aucun appel rв”ңвҢҗcent\"\n    return currentHistory\n      .map((item) =>\n        `${item.method} ${item.endpoint} О“ГҘГҶ ${item.responseStatus ?? \"-\"} (${item.responseTime ?? \"-\"}ms)`\n      )\n      .join(\"\\n\")\n  }, [currentHistory])\n\n  const extractJsonBlock = (text: string) => {\n    const jsonBlockMatch = text.match(/```json\\s*([\\s\\S]*?)```/i)\n    if (jsonBlockMatch) return jsonBlockMatch[1]\n    const firstBrace = text.indexOf(\"{\")\n    const lastBrace = text.lastIndexOf(\"}\")\n    if (firstBrace !== -1 && lastBrace !== -1) {\n      return text.slice(firstBrace, lastBrace + 1)\n    }\n    return text\n  }\n\n  const buildFullUrl = (url: string) => {\n    if (url.startsWith(\"http\")) return url\n    const base = selectedProject?.port ? `http://localhost:${selectedProject.port}` : \"http://localhost\"\n    const normalisedUrl = url.startsWith(\"/\") ? url : `/${url}`\n    return `${base}${normalisedUrl}`\n  }\n\n  const buildCurlSnippet = (request: SuggestedRequest) => {\n    const finalUrl = buildFullUrl(request.url)\n    const headers = request.headers\n      ? Object.entries(request.headers).map(([key, value]) => `-H \"${key}: ${value}\"`).join(\"\\n      \")\n      : \"\"\n    const body = request.body ? `--data-raw '${request.body.replace(/'/g, \"'\\\\''\")}'` : \"\"\n    return [\"curl\", `-X ${request.method}`, headers, body, `\"${finalUrl}\"`]\n      .filter(Boolean)\n      .join(\"\\n      \")\n  }\n\n  const buildFetchSnippet = (request: SuggestedRequest) => {\n    const finalUrl = buildFullUrl(request.url)\n    const headersObject = request.headers ?? {}\n    const bodyPart = request.body ? `  body: ${JSON.stringify(request.body)},\\n` : \"\"\n    return `fetch(\"${finalUrl}\", {\n  method: \"${request.method}\",\n  headers: ${JSON.stringify(headersObject, null, 2)},\n${bodyPart}})\n  .then((res) => res.text())\n  .then((text) => console.log(text));`\n  }\n\n  const copyToClipboard = async (text: string, label: string) => {\n    try {\n      await navigator.clipboard.writeText(text)\n      toast({ title: `${label} copiв”ңвҢҗ` })\n    } catch {\n      toast({ title: `Impossible de copier ${label}`, variant: \"destructive\" })\n    }\n  }\n\n  const systemInstructions = (() => {\n    const selectedProjectInfo = selectedProject\n      ? `Projet sв”ңвҢҗlectionnв”ңвҢҗ : ${selectedProject.name} (${selectedProject.framework})\\nPort : ${selectedProject.port ?? \"inconnu\"}\\nRoutes dв”ңвҢҗtectв”ңвҢҗes : ${selectedProject.routes.length}`\n      : \"Aucun projet sв”ңвҢҗlectionnв”ңвҢҗ.\"\n\n    return `Tu es un assistant IA global pour un outil de tests d'API. Tu disposes du contexte suivant :\\n${selectedProjectInfo}\\n\\nRoutes dв”ңвҢҗtectв”ңвҢҗes :\\n${routeSummary}\\n\\nHistorique des appels :\\n${requestSummary}\\n\\nRв”ңвҢҗponds de maniв”ңВҝre claire, concise et aide l'utilisateur в”ңГЎ comprendre, corriger ou enrichir ses requв”ңВ¬tes et endpoints.`\n  })();\n\n  const handleProviderChange = (value: AIProvider) => {\n    setProvider(value)\n    setApiKey(loadApiKey(value))\n    setSendStatus(null)\n  }\n\n  const handleSend = async () => {\n    const prompt = query.trim()\n    if (!prompt) return\n    if (provider !== \"ollama\" && !isProviderConfigured) {\n      setSendStatus(\"Enregistre la configuration IA avant d'envoyer un message.\")\n      toast({ title: \"Enregistre la configuration IA avant d'envoyer un message.\", variant: \"destructive\" })\n      return\n    }\n\n    setSendStatus(\"Envoi en cours...\")\n    const userMessage: ChatMessage = { role: \"user\", content: prompt }\n    setMessages((prev) => [...prev, userMessage])\n    try {\n      addNotification?.({ title: \"Message envoyв”ңвҢҗ\", body: prompt, type: \"info\" })\n    } catch {}\n    setQuery(\"\")\n    setLoading(true)\n\n    try {\n      if (provider !== \"ollama\") saveApiKey(provider, apiKey)\n\n      const ollamaConfig = provider === \"ollama\" ? getOllamaConfig() : null\n      const response = await fetch(\"/api/proxy-ai\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({\n          provider,\n          apiKey,\n          model:\n            provider === \"anthropic\"\n              ? \"claude-sonnet-4-20250514\"\n              : provider === \"openai\"\n              ? \"gpt-3.5-turbo\"\n              : provider === \"openrouter\"\n              ? \"openai/gpt-5.2\"\n              : provider === \"gemini\"\n              ? \"gemini-2.0-flash\"\n              : ollamaConfig?.model || \"llama2\",\n          host: ollamaConfig?.host,\n          port: ollamaConfig?.port,\n          system: systemInstructions,\n          message: prompt,\n        }),\n      })\n\n      const rawText = await response.text()\n      let data: { error?: string | { message?: string }; content?: string } = {}\n      try {\n        data = JSON.parse(rawText)\n      } catch {\n        data = { content: rawText }\n      }\n\n      if (!response.ok) {\n        const errorMsg = typeof data.error === \"object\" ? data.error?.message : data.error;\n        const errorMessage =\n          errorMsg || rawText || \"Erreur IA\"\n        const providerHint =\n          provider === \"openai\" || provider === \"openrouter\"\n            ? \"Vв”ңвҢҗrifie ta clв”ңвҢҗ et ton quota sur le provider choisi.\"\n            : \"Vв”ңвҢҗrifie ta configuration provider.\"\n        const statusMessage = `${provider.toUpperCase()} error: ${errorMessage}. ${providerHint}`\n        setSendStatus(statusMessage)\n        toast({ title: statusMessage, variant: \"destructive\" })\n        return\n      }\n\n      const assistantContent =\n        typeof data.content === \"string\" && data.content.trim()\n          ? data.content\n          : typeof rawText === \"string\" && rawText.trim()\n          ? rawText\n          : \"L'IA n'a pas renvoyв”ңвҢҗ de rв”ңвҢҗponse. Vв”ңвҢҗrifie ta configuration et rв”ңвҢҗessaye.\"\n\n      const assistantMessage: ChatMessage = {\n        role: \"assistant\",\n        content: assistantContent,\n      }\n      setMessages((prev) => [...prev, assistantMessage])\n      try {\n        addNotification?.({ title: \"Rв”ңвҢҗponse IA reв”ңВәue\", body: assistantContent, type: \"info\" })\n      } catch {}\n      setSendStatus(\"Rв”ңвҢҗponse reв”ңВәue\")\n    } catch (error) {\n      const errorMessage = `Erreur IA : ${String(error)}`\n      setSendStatus(errorMessage)\n      toast({ title: errorMessage, variant: \"destructive\" })\n    } finally {\n      setLoading(false)\n    }\n  }\n\n\n\n  return (\n    <div className=\"flex min-h-screen bg-slate-100\">\n      <ApiSidebar activePage=\"ai-insights\" collapsed={isCollapsed} onCollapse={toggleSidebar} />\n\n      <div\n        className={cn(\n          \"flex flex-1 flex-col overflow-hidden transition-all duration-300 ease-in-out\",\n          isCollapsed ? \"ml-[60px]\" : \"ml-64\",\n          \"max-[916px]:ml-[60px]\"\n        )}\n      >\n        <header className=\"flex h-14 items-center justify-between border-b border-border bg-background px-6\">\n          <div className=\"flex items-center gap-2\">\n            <div className=\"flex size-8 items-center justify-center rounded border border-border\">\n              <div className=\"size-4 rounded-sm bg-foreground\" />\n            </div>\n          </div>\n\n          <div className=\"flex items-center gap-4\">\n            <div className=\"grid items-center gap-2 sm:grid-cols-2\">\n              <DropdownMenu>\n                <DropdownMenuTrigger asChild>\n                  <Button variant=\"outline\" size=\"sm\" className=\"h-8 gap-2 border-dashed font-normal\">\n                    <div className=\"size-2 rounded-full bg-slate-400\" />\n                    {selectedProject ? selectedProject.name : \"Aucun projet\"}\n                    <ChevronsUpDown className=\"size-3 text-muted-foreground\" />\n                  </Button>\n                </DropdownMenuTrigger>\n                <DropdownMenuContent align=\"end\" className=\"w-[220px]\">\n                  <DropdownMenuLabel className=\"text-xs text-muted-foreground\">Projets</DropdownMenuLabel>\n                  <DropdownMenuSeparator />\n                  {projects.map((p) => (\n                    <DropdownMenuItem\n                      key={p.id}\n                      onClick={() => setSelectedProject(p.id)}\n                      className=\"flex items-center gap-2\"\n                    >\n                      <span className=\"truncate flex-1\">{p.name}</span>\n                      {selectedProjectId === p.id && <Check className=\"size-3.5 text-primary\" />}\n                    </DropdownMenuItem>\n                  ))}\n                </DropdownMenuContent>\n              </DropdownMenu>\n\n              <DropdownMenu>\n                <DropdownMenuTrigger asChild>\n                  <Button variant=\"outline\" size=\"sm\" className=\"h-8 gap-2 border-dashed font-normal\">\n                    {PROVIDERS.find((item) => item.value === provider)?.label}\n                    <ChevronsUpDown className=\"size-3 text-muted-foreground\" />\n                  </Button>\n                </DropdownMenuTrigger>\n                <DropdownMenuContent align=\"end\" className=\"w-[160px]\">\n                  <DropdownMenuLabel className=\"text-xs text-muted-foreground\">Provider</DropdownMenuLabel>\n                  <DropdownMenuSeparator />\n                  {PROVIDERS.map((item) => (\n                    <DropdownMenuItem\n                      key={item.value}\n                      onClick={() => handleProviderChange(item.value)}\n                      className=\"flex items-center gap-2\"\n                    >\n                      <span className=\"flex-1 truncate\">{item.label}</span>\n                      {provider === item.value && <Check className=\"size-3.5 text-primary\" />}\n                    </DropdownMenuItem>\n                  ))}\n                </DropdownMenuContent>\n              </DropdownMenu>\n            </div>\n\n            <div className=\"relative hidden md:block\">\n              <Input type=\"text\" placeholder=\"Recherche projet, endpoint...\" className=\"h-9 w-64 bg-muted/50 pl-3 text-sm\" />\n            </div>\n\n            <EnvironmentSelector />\n\n            <button className=\"flex size-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground\">\n              <Users className=\"size-5\" />\n            </button>\n            <DropdownMenu>\n              <DropdownMenuTrigger asChild>\n                <button className=\"relative flex size-9 items-center justify-center rounded-lg text-muted-foreground transition-colors hover:bg-accent hover:text-foreground\">\n                  <Bell className=\"size-5\" />\n                  {notifications && notifications.some((n) => !n.read) && (\n                    <span className=\"absolute -top-0.5 -right-0.5 h-2 w-2 rounded-full bg-destructive\" />\n                  )}\n                </button>\n              </DropdownMenuTrigger>\n              <DropdownMenuContent align=\"end\" className=\"w-[300px]\">\n                <DropdownMenuLabel className=\"text-xs text-muted-foreground\">Notifications</DropdownMenuLabel>\n                <DropdownMenuSeparator />\n                {(systemNotificationPermission !== \"granted\" && systemNotificationPermission !== \"unsupported\") && (\n                  <div className=\"p-3 border-b\">\n                    <button\n                      className=\"text-sm text-primary\"\n                      onClick={async () => {\n                        try {\n                          const res = await requestSystemNotificationPermission()\n                          if (res === \"granted\") {\n                            toast({ title: \"Notifications systв”ңВҝme activв”ңвҢҗes\", meta: { event: \"notificationPermission\" } } as any)\n                          } else if (res === \"denied\") {\n                            toast({ title: \"Permission refusв”ңвҢҗe\", variant: \"destructive\", meta: { event: \"notificationPermission\" } } as any)\n                          }\n                        } catch {}\n                      }}\n                    >\n                      Activer notifications systв”ңВҝme\n                    </button>\n                  </div>\n                )}\n                {(!notifications || notifications.length === 0) ? (\n                  <div className=\"p-3 text-sm text-muted-foreground\">Aucune notification</div>\n                ) : (\n                  notifications.map((n) => (\n                    <DropdownMenuItem key={n.id} onClick={() => markNotificationRead(n.id)} className=\"flex flex-col items-start gap-1\">\n                      <div className=\"flex items-center justify-between w-full\">\n                        <span className=\"text-sm font-medium\">{n.title}</span>\n                        <span className=\"text-xs text-muted-foreground\">{new Date(n.createdAt).toLocaleTimeString()}</span>\n                      </div>\n                      {n.body && <div className=\"text-xs text-muted-foreground\">{n.body}</div>}\n                    </DropdownMenuItem>\n                  ))\n                )}\n                <DropdownMenuSeparator />\n                <div className=\"p-2\">\n                  <button className=\"text-xs text-muted-foreground\" onClick={() => clearNotifications()}>Effacer</button>\n                </div>\n              </DropdownMenuContent>\n            </DropdownMenu>\n          </div>\n        </header>\n\n        <main className=\"flex-1 overflow-auto bg-slate-100 p-6\">\n          <div className=\"mx-auto flex w-full max-w-5xl flex-col gap-6 px-4\">\n            <section className=\"rounded-[32px] border border-border bg-white/95 p-6 shadow-[0_35px_60px_-30px_rgba(15,23,42,0.35)] backdrop-blur-xl\">\n              <div className=\"mb-6 rounded-[28px] border border-slate-200 bg-slate-50 p-5\">\n                <div className=\"mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between\">\n                  <div>\n                    <p className=\"text-sm font-semibold text-foreground\">Gв”ңвҢҗnв”ңвҢҗrer des tests automatiques</p>\n                    <p className=\"text-xs text-muted-foreground\">\n                      Basв”ңвҢҗ sur une requв”ңВ¬te sв”ңвҢҗlectionnв”ңвҢҗe de ton historique. Obtiens un test Jest + supertest, un exemple Fetch natif et une commande cURL.\n                    </p>\n                  </div>\n                  <Button\n                    type=\"button\"\n                    onClick={handleGenerateTests}\n                    disabled={!selectedHistoryRequest || generatingTests || (provider !== \"ollama\" && !isProviderConfigured)}\n                  >\n                    {generatingTests ? <Loader2 className=\"size-4 animate-spin\" /> : \"Gв”ңвҢҗnв”ңвҢҗrer les tests\"}\n                  </Button>\n                </div>\n\n                <div className=\"grid gap-4 lg:grid-cols-[0.9fr_1.1fr]\">\n                  <div className=\"space-y-4\">\n                    {recentHistory.length > 0 ? (\n                      <div>\n                        <label className=\"mb-2 block text-xs font-medium uppercase tracking-[0.24em] text-muted-foreground\">\n                          Requв”ңВ¬te choisie\n                        </label>\n                        <select\n                          value={selectedHistoryRequestId ?? recentHistory[0]?.id ?? \"\"}\n                          onChange={(event) => setSelectedHistoryRequestId(event.target.value)}\n                          className=\"w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-foreground outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20\"\n                        >\n                          {recentHistory.map((request) => (\n                            <option key={request.id} value={request.id}>\n                              {request.method} {request.endpoint || request.url} О“ГҮГ¶ {request.responseStatus ?? \"?\"} О“ГҮГі {request.responseTime ?? \"?\"}ms\n                            </option>\n                          ))}\n                        </select>\n                      </div>\n                    ) : (\n                      <div className=\"rounded-2xl border border-dashed border-slate-300 bg-white p-4 text-sm text-muted-foreground\">\n                        Aucune requв”ңВ¬te enregistrв”ңвҢҗe dans l'historique pour gв”ңвҢҗnв”ңвҢҗrer des tests.\n                      </div>\n                    )}\n\n                    {selectedHistoryRequest && (\n                      <div className=\"rounded-2xl border border-border bg-white p-4 text-sm text-slate-700\">\n                        <p className=\"font-semibold text-foreground\">{selectedHistoryRequest.method} {selectedHistoryRequest.endpoint || selectedHistoryRequest.url}</p>\n                        <p className=\"mt-1 text-xs text-muted-foreground\">\n                          Statut : {selectedHistoryRequest.responseStatus ?? \"-\"} О“ГҮГі {selectedHistoryRequest.responseTime ?? \"-\"}ms\n                        </p>\n                        {selectedHistoryRequest.headers && Object.keys(selectedHistoryRequest.headers).length > 0 && (\n                          <p className=\"mt-3 break-words text-xs\">\n                            <span className=\"font-medium\">Headers :</span> {JSON.stringify(selectedHistoryRequest.headers)}\n                          </p>\n                        )}\n                        {selectedHistoryRequest.body ? (\n                          <p className=\"mt-3 whitespace-pre-wrap break-words text-xs\">\n                            <span className=\"font-medium\">Body :</span> {selectedHistoryRequest.body}\n                          </p>\n                        ) : null}\n                      </div>\n                    )}\n                  </div>\n\n                  <div className=\"space-y-4\">\n                    {generatedTests ? (\n                      <div className=\"space-y-4\">\n                        {[\n                          { title: \"Jest + supertest\", content: generatedTests.jest, variant: \"Jest\" },\n                          { title: \"Fetch natif\", content: generatedTests.fetch, variant: \"Fetch\" },\n                          { title: \"cURL\", content: generatedTests.curl, variant: \"cURL\" },\n                        ].map((block) => (\n                          <div key={block.title} className=\"rounded-2xl border border-border bg-white p-4\">\n                            <div className=\"mb-3 flex items-center justify-between gap-3\">\n                              <p className=\"text-sm font-semibold text-foreground\">{block.title}</p>\n                              <Button\n                                type=\"button\"\n                                variant=\"outline\"\n                                size=\"sm\"\n                                onClick={() => copyToClipboard(block.content || generatedTests.raw, block.variant)}\n                              >\n                                Copier\n                              </Button>\n                            </div>\n                            <pre className=\"max-h-48 overflow-auto whitespace-pre-wrap rounded-2xl bg-slate-50 p-3 text-xs leading-5 text-slate-700\">\n                              {block.content || generatedTests.raw || \"Aucun contenu disponible.\"}\n                            </pre>\n                          </div>\n                        ))}\n                      </div>\n                    ) : (\n                      <div className=\"rounded-2xl border border-dashed border-slate-300 bg-white p-6 text-sm text-muted-foreground\">\n                        Clique sur в”¬ВҪ Gв”ңвҢҗnв”ңвҢҗrer les tests в”¬в•— pour crв”ңвҢҗer un test Jest, une requв”ңВ¬te Fetch et un exemple cURL в”ңГЎ partir de la requв”ңВ¬te sв”ңвҢҗlectionnв”ңвҢҗe.\n                      </div>\n                    )}\n                  </div>\n                </div>\n              </div>\n\n              <div className=\"mt-6 rounded-[28px] border border-slate-50 bg-slate-50 p-5\">\n                <div className=\"mb-4 flex items-center justify-between gap-3\">\n                  <div>\n                    <p className=\"text-sm font-semibold text-foreground\">Conversation</p>\n                    <p className=\"text-xs text-muted-foreground\">Ton assistant est prв”ңВ¬t в”ңГЎ rв”ңвҢҗpondre ici.</p>\n                  </div>\n                  <span className=\"rounded-full bg-muted px-3 py-1 text-xs text-muted-foreground\">{messages.length} messages</span>\n                </div>\n\n                <div className=\"flex flex-col gap-4\">\n                  {messages.length === 0 ? (\n                    <div className=\"grid gap-4 rounded-[28px] border border-dashed border-slate-200 bg-slate-50 p-6 text-center text-slate-700\">\n                      <div className=\"mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-fuchsia-200 via-sky-200 to-blue-300 shadow-lg\">\n                        <Sparkles className=\"size-8 text-slate-900\" />\n                      </div>\n                      <div>\n                        <h2 className=\"text-2xl font-semibold text-foreground\">Monu IA</h2>\n                        <p className=\"mt-2 max-w-xl mx-auto text-sm text-muted-foreground\">\n                          Obtiens des rв”ңвҢҗponses sur ton projet, tes routes et tes tests d'API. Sв”ңвҢҗlectionne un projet et un provider, puis lance la conversation.\n                        </p>\n                      </div>\n                      <div className=\"grid gap-3 sm:grid-cols-2\">\n                        {SUGGESTIONS.map((suggestion) => (\n                          <button\n                            key={suggestion}\n                            type=\"button\"\n                            onClick={() => setQuery(suggestion)}\n                            className=\"rounded-2xl border border-slate-200 bg-white px-4 py-4 text-left text-sm text-slate-700 hover:border-slate-300 hover:bg-slate-50 transition-all\"\n                          >\n                            {suggestion}\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n                  ) : (\n                    <div className=\"space-y-4\">\n                      {messages.map((message, index) => (\n                        <div\n                          key={`${message.role}-${index}`}\n                          className={cn(\n                            \"rounded-[28px] border p-5 text-sm leading-6\",\n                            message.role === \"assistant\"\n                              ? \"border-border bg-white shadow-sm\"\n                              : \"ml-auto max-w-[80%] border-border bg-slate-100\"\n                          )}\n                        >\n                          <div className=\"mb-2 flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-muted-foreground\">\n                            <span>{message.role === \"assistant\" ? \"Monu IA\" : \"Moi\"}</span>\n                          </div>\n                          <p className=\"whitespace-pre-wrap text-foreground\">{message.content}</p>\n                        </div>\n                      ))}\n                    </div>\n                  )}\n                </div>\n              </div>\n\n              <div className=\"mt-6 rounded-[28px] border border-border bg-slate-50 p-5\">\n                <label className=\"block text-sm font-medium text-foreground\">Que veux-tu demander ?</label>\n                <div className=\"relative mt-3\">\n                  <textarea\n                    value={query}\n                    onChange={(event) => setQuery(event.target.value)}\n                    onKeyDown={(e) => {\n                      if (e.key === \"Enter\" && !e.shiftKey) {\n                        e.preventDefault()\n                        handleSend()\n                      }\n                    }}\n                    rows={3}\n                    className=\"w-full resize-none rounded-[20px] border border-slate-200 bg-white px-4 py-4 pr-20 text-sm text-foreground outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20\"\n                    placeholder=\"в”ңГ«cris ta question ici... (Entrв”ңвҢҗe pour envoyer, Shift+Entrв”ңвҢҗe pour nouvelle ligne)\"\n                  />\n                  <div className=\"absolute right-3 bottom-3 flex items-center gap-2\">\n                    <Button\n                      type=\"button\"\n                      onClick={handleSend}\n                      disabled={loading || !query.trim() || (provider !== \"ollama\" && !isProviderConfigured)}\n                      className=\"h-9 w-9 rounded-full p-0\"\n                    >\n                      {loading ? <Loader2 className=\"size-4 animate-spin\" /> : <Send className=\"size-4\" />}\n                    </Button>\n                  </div>\n                </div>\n                <div className=\"mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between\">\n                  <div className=\"flex flex-wrap gap-2\">\n                    {STYLE_TAGS.map((tag) => (\n                      <button\n                        key={tag}\n                        type=\"button\"\n                        onClick={() => setQuery(tag)}\n                        className=\"inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-2 text-xs text-slate-600 hover:bg-slate-100 transition-all\"\n                      >\n                        <Plus size={12} /> {tag}\n                      </button>\n                    ))}\n                    <button\n                      type=\"button\"\n                      onClick={() => setQuery(\"\")}\n                      className=\"inline-flex h-10 items-center justify-center rounded-full border border-slate-200 bg-white px-3 text-xs text-slate-500 hover:bg-slate-100 transition-all\"\n                    >\n                      <RefreshCw size={14} /> Rв”ңвҢҗinitialiser\n                    </button>\n                  </div>\n                  <div className=\"sm:w-auto\" />\n                  {sendStatus && (\n                    <p className=\"text-xs text-foreground\">{sendStatus}</p>\n                  )}\n                </div>\n              </div>\n            </section>\n          </div>\n        </main>\n      </div>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\app\\api\\github-import\\route.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":120,"column":87,"messageId":"unexpectedAny","endLine":120,"endColumn":90,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3638,3641],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3638,3641],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":121,"column":17,"messageId":"unexpectedAny","endLine":121,"endColumn":20,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[3662,3665],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[3662,3665],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"no-useless-escape","severity"