                className={cn(\"w-full text-left p-2 rounded-md\", activeSection === \"ai\" ? \"bg-primary/10 font-semibold\" : \"hover:bg-muted\")}\n                  onClick={() => setActiveSection(\"ai\")}\n                >\n                  Assistant IA\n                </button>\n                <button\n                  className={cn(\"w-full text-left p-2 rounded-md\", activeSection === \"notifications\" ? \"bg-primary/10 font-semibold\" : \"hover:bg-muted\")}\n                  onClick={() => setActiveSection(\"notifications\")}\n                >\n                  Notifications\n                </button>\n                <button\n                  className={cn(\"w-full text-left p-2 rounded-md\", activeSection === \"sync\" ? \"bg-primary/10 font-semibold\" : \"hover:bg-muted\")}\n                  onClick={() => setActiveSection(\"sync\")}\n                >\n                  Import / Export\n                </button>\n                <button\n                  className={cn(\"w-full text-left p-2 rounded-md text-destructive\", activeSection === \"account\" ? \"bg-destructive/10 font-semibold\" : \"hover:bg-muted\")}\n                  onClick={() => setActiveSection(\"account\")}\n                >\n                  Actions du compte\n                </button>\n              </nav>\n            </aside>\n\n            <div className=\"flex-1 space-y-6\">\n              {/* Profile & Security */}\n              {activeSection === \"profile\" ? (\n                <section className=\"rounded-3xl border border-border bg-card p-6\">\n                <div className=\"mb-4 flex items-center gap-3 text-foreground\">\n                  <div className=\"size-5 text-primary\">\n                    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" className=\"w-6 h-6\">\n                      <path d=\"M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4z\"></path>\n                      <path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"></path>\n                    </svg>\n                  </div>\n                  <div>\n                    <h2 className=\"text-lg font-semibold\">Sв”ңвҢҗcuritв”ңвҢҗ</h2>\n                    <p className=\"text-sm text-muted-foreground\">Informations du compte et options de sв”ңвҢҗcuritв”ңвҢҗ.</p>\n                  </div>\n                </div>\n\n                <div className=\"space-y-4\">\n                  <div>\n                    <label className=\"mb-2 block text-sm font-medium text-foreground\">Adresse email</label>\n                    <Input value={email} onChange={(e) => setEmail(e.target.value)} placeholder=\"Non renseignв”ңвҢҗ\" />\n                    <p className=\"mt-2 text-xs text-muted-foreground\">L'email associв”ңвҢҗ au compte (local).</p>\n                  </div>\n\n                  <div className=\"flex items-center justify-between rounded-2xl bg-muted p-4\">\n                    <div>\n                      <p className=\"text-sm\">Vв”ңвҢҗrification en deux в”ңвҢҗtapes</p>\n                      <p className=\"text-xs text-muted-foreground mt-1\">Renforce la sв”ңвҢҗcuritв”ңвҢҗ du compte.</p>\n                    </div>\n                    <div className=\"flex items-center gap-3\">\n                      <span className=\"text-sm\">{twoFactorEnabled ? \"Activв”ңвҢҗe\" : \"Dв”ңвҢҗsactivв”ңвҢҗe\"}</span>\n                      <Button variant={twoFactorEnabled ? \"secondary\" : \"outline\"} onClick={handleToggle2FA}>\n                        {twoFactorEnabled ? \"Dв”ңвҢҗsactiver\" : \"Activer\"}\n                      </Button>\n                    </div>\n                  </div>\n\n                  <div className=\"flex items-center gap-3\">\n                    <Button onClick={saveUserSettings}>Enregistrer profil</Button>\n                    <span className=\"text-sm text-muted-foreground\">Paramв”ңВҝtres personnels</span>\n                  </div>\n                </div>\n                </section>\n              ) : null}\n\n              {/* Assistant IA */}\n              {activeSection === \"ai\" ? (\n                <section className=\"rounded-3xl border border-border bg-card p-6\">\n                <div className=\"mb-4 flex items-center gap-3 text-foreground\">\n                  <Sparkles className=\"size-5 text-primary\" />\n                  <div>\n                    <h2 className=\"text-lg font-semibold\">Assistant IA</h2>\n                    <p className=\"text-sm text-muted-foreground\">Sв”ңвҢҗlectionnez votre fournisseur et stockez la clв”ңвҢҗ API localement.</p>\n                  </div>\n                </div>\n\n                <div className=\"space-y-4\">\n                  <div>\n                    <label className=\"mb-2 block text-sm font-medium text-foreground\">Fournisseur IA</label>\n                    <Select value={provider} onValueChange={(value) => handleProviderChange(value as AIProvider)}>\n                      <SelectTrigger className=\"w-full\">\n                        <SelectValue placeholder=\"Choisir un fournisseur\" />\n                      </SelectTrigger>\n                      <SelectContent>\n                        {AI_PROVIDERS.map((option) => (\n                          <SelectItem key={option.value} value={option.value}>\n                            {option.label}\n                          </SelectItem>\n                        ))}\n                      </SelectContent>\n                    </Select>\n                  </div>\n\n                  <div>\n                    <label className=\"mb-2 block text-sm font-medium text-foreground\">Clв”ңвҢҗ API</label>\n                    <Input\n                      type=\"password\"\n                      value={apiKey}\n                      onChange={(event) => setApiKey(event.target.value)}\n                      placeholder=\"Entrez votre clв”ңвҢҗ API\"\n                      disabled={provider === \"ollama\"}\n                    />\n                    <p className=\"mt-2 text-xs text-muted-foreground\">\n                      {provider === \"ollama\"\n                        ? \"Ollama est exв”ңвҢҗcutв”ңвҢҗ localement et ne nв”ңвҢҗcessite pas de clв”ңвҢҗ API.\"\n                        : \"La clв”ңвҢҗ est conservв”ңвҢҗe dans le stockage local du navigateur et uniquement utilisв”ңвҢҗe par l'assistant IA.\"}\n                    </p>\n                  </div>\n\n                  {provider === \"ollama\" ? (\n                    <div className=\"space-y-4 rounded-2xl border border-slate-200 bg-muted p-4\">\n                      <div>\n                        <label className=\"mb-2 block text-sm font-medium text-foreground\">Host</label>\n                        <Input value={ollamaHost} onChange={(event) => setOllamaHost(event.target.value)} placeholder=\"127.0.0.1\" />\n                      </div>\n                      <div>\n                        <label className=\"mb-2 block text-sm font-medium text-foreground\">Port</label>\n                        <Input value={ollamaPort} onChange={(event) => setOllamaPort(event.target.value)} placeholder=\"11434\" />\n                      </div>\n                      <div>\n                        <label className=\"mb-2 block text-sm font-medium text-foreground\">Modв”ңВҝle Ollama</label>\n                        <Input value={ollamaModel} onChange={(event) => setOllamaModel(event.target.value)} placeholder=\"llama2\" />\n                        <p className=\"mt-2 text-xs text-muted-foreground\">Modв”ңВҝle local Ollama installв”ңвҢҗ sur votre machine. Par exemple : <code>llama2</code> ou <code>phi:latest</code>.</p>\n                      </div>\n                      <p className=\"text-xs text-muted-foreground\">Configure le port local et le modв”ңВҝle Ollama в”ңГЎ utiliser pour les appels IA.</p>\n                    </div>\n                  ) : null}\n\n                  <div className=\"flex items-center gap-3\">\n                    <Button onClick={handleSaveAIConfig}>Sauvegarder</Button>\n                    <span className=\"text-sm text-muted-foreground\">Derniв”ңВҝre configuration : {provider.toUpperCase()}</span>\n                  </div>\n                </div>\n                </section>\n              ) : null}\n\n              {/* Notifications */}\n              {activeSection === \"notifications\" ? (\n                <section className=\"rounded-3xl border border-border bg-card p-6\">\n                <div className=\"mb-4 flex items-center gap-3 text-foreground\">\n                  <Bell className=\"size-5 text-secondary\" />\n                  <div>\n                    <h2 className=\"text-lg font-semibold\">Notifications</h2>\n                    <p className=\"text-sm text-muted-foreground\">Gв”ңвҢҗrez l'accв”ңВҝs aux notifications systв”ңВҝme de votre navigateur.</p>\n                  </div>\n                </div>\n\n                <div className=\"space-y-4\">\n                  <div className=\"flex items-center justify-between\">\n                    <div>\n                      <p className=\"text-sm\">Activer les notifications (toasts)</p>\n                      <p className=\"text-xs text-muted-foreground\">Les notifications apparaв”ңВ«tront sous forme de toasts dans l'interface.</p>\n                    </div>\n                    <Switch checked={pushEnabled} onCheckedChange={() => togglePushEnabled()} />\n                  </div>\n\n                  <div className=\"rounded-2xl bg-muted p-4\">\n                    <p className=\"text-sm font-medium\">в”ңГ«vв”ңвҢҗnements dв”ңвҢҗclenchant des toasts</p>\n                    <div className=\"mt-3 space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <div>\n                          <p className=\"text-sm\">Requв”ңВ¬te terminв”ңвҢҗe</p>\n                          <p className=\"text-xs text-muted-foreground\">Affiche un toast quand une requв”ңВ¬te se termine.</p>\n                        </div>\n                        <Checkbox checked={notifyEvents.requestComplete} onCheckedChange={() => toggleNotifyEvent('requestComplete')} />\n                      </div>\n\n                      <div className=\"flex items-center justify-between\">\n                        <div>\n                          <p className=\"text-sm\">Exв”ңвҢҗcution de collection terminв”ңвҢҗe</p>\n                          <p className=\"text-xs text-muted-foreground\">Toast в”ңГЎ la fin d'une exв”ңвҢҗcution de collection.</p>\n                        </div>\n                        <Checkbox checked={notifyEvents.collectionComplete} onCheckedChange={() => toggleNotifyEvent('collectionComplete')} />\n                      </div>\n\n                      <div className=\"flex items-center justify-between\">\n                        <div>\n                          <p className=\"text-sm\">Rв”ңвҢҗponse IA reв”ңВәue</p>\n                          <p className=\"text-xs text-muted-foreground\">Toast quand l'assistant IA renvoie une rв”ңвҢҗponse.</p>\n                        </div>\n                        <Checkbox checked={notifyEvents.aiResponse} onCheckedChange={() => toggleNotifyEvent('aiResponse')} />\n                      </div>\n\n                      <div className=\"flex items-center justify-between\">\n                        <div>\n                          <p className=\"text-sm\">Erreur IA</p>\n                          <p className=\"text-xs text-muted-foreground\">Toast pour les erreurs renvoyв”ңвҢҗes par le proxy IA.</p>\n                        </div>\n                        <Checkbox checked={notifyEvents.aiError} onCheckedChange={() => toggleNotifyEvent('aiError')} />\n                      </div>\n\n                      <div className=\"flex items-center justify-between\">\n                        <div>\n                          <p className=\"text-sm\">Import / Export terminв”ңвҢҗ</p>\n                          <p className=\"text-xs text-muted-foreground\">Toast aprв”ңВҝs import/export des collections.</p>\n                        </div>\n                        <Checkbox checked={notifyEvents.importExport} onCheckedChange={() => toggleNotifyEvent('importExport')} />\n                      </div>\n                    </div>\n                  </div>\n\n                  <div className=\"flex items-center gap-3\">\n                    <Button onClick={handleRequestNotifications}>Autoriser les notifications</Button>\n                    <Button variant=\"secondary\" onClick={handleTestPush}>Tester un toast</Button>\n                    <span className=\"text-sm text-muted-foreground\">Permission navigateur : {systemNotificationPermission ?? \"non disponible\"}</span>\n                  </div>\n                </div>\n                </section>\n              ) : null}\n\n              {/* Sync / Import Export */}\n              {activeSection === \"sync\" ? (\n                <section className=\"rounded-3xl border border-border bg-card p-6\">\n                  <div className=\"flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between\">\n                    <div className=\"flex items-start gap-4\">\n                      <div className=\"flex size-11 shrink-0 items-center justify-center rounded-2xl bg-primary/10\">\n                        <svg className=\"size-5 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n                          <path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\" />\n                          <circle cx=\"9\" cy=\"7\" r=\"4\" />\n                        </svg>\n                      </div>\n                      <div>\n                        <h2 className=\"text-lg font-semibold text-foreground\">Sync d'в”ңвҢҗquipe</h2>\n                        <p className=\"mt-0.5 text-sm text-muted-foreground\">Exportez et importez vos collections et environnements.</p>\n                      </div>\n                    </div>\n                    <Button id=\"open-sync-modal-btn\" onClick={() => setSyncModalOpen(true)} className=\"shrink-0 flex items-center gap-2\">\n                      Import / Export\n                    </Button>\n                  </div>\n                </section>\n              ) : null}\n\n              {/* Account actions */}\n              {activeSection === \"account\" ? (\n                <section className=\"rounded-3xl border border-border bg-card p-6\">\n                  <div className=\"mb-4\">\n                    <h2 className=\"text-lg font-semibold\">Actions du compte</h2>\n                    <p className=\"text-sm text-muted-foreground\">Dв”ңвҢҗsactivez ou supprimez votre compte (simulation).</p>\n                  </div>\n\n                  <div className=\"space-y-3\">\n                    <div className=\"flex items-center justify-between rounded-2xl bg-muted p-4\">\n                      <div>\n                        <p className=\"font-semibold\">Dв”ңвҢҗsactiver mon compte</p>\n                        <p className=\"text-xs text-muted-foreground mt-1\">Le compte sera rв”ңвҢҗactivв”ңвҢҗ lorsque vous vous reconnecterez.</p>\n                      </div>\n                      <Button variant=\"ghost\" onClick={handleDeactivateAccount}>Dв”ңвҢҗsactiver</Button>\n                    </div>\n\n                    <div className=\"flex items-center justify-between rounded-2xl bg-muted p-4\">\n                      <div>\n                        <p className=\"font-semibold\">Supprimer mon compte</p>\n                        <p className=\"text-xs text-muted-foreground mt-1\">Suppression permanente et irrв”ңвҢҗversible.</p>\n                      </div>\n                      <Button variant=\"destructive\" onClick={handleDeleteAccount}>Supprimer</Button>\n                    </div>\n                  </div>\n                </section>\n              ) : null}\n            </div>\n          </div>\n\n          \n        </div>\n      </div>\n\n      <ImportExportModal open={syncModalOpen} onClose={() => setSyncModalOpen(false)} />\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\DiffPanel.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\api-header.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\api-sidebar.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\collections-drawer.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\collections-modal.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\collections-panel.tsx","messages":[{"ruleId":null,"fatal":true,"severity":2,"message":"Parsing error: '}' expected.","line":945,"column":0}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\"\n\nimport { useState, useRef } from \"react\"\nimport {\n  ChevronDown,\n  ChevronRight,\n  FolderPlus,\n  MoreHorizontal,\n  Plus,\n  Lock,\n  Users,\n  Package,\n  Trash2,\n  Edit2,\n  Search,\n  Download,\n  LayoutGrid,\n  List,\n  CheckSquare,\n  Square,\n  X,\n  Layers,\n  Import,\n  Play,\n} from \"lucide-react\"\nimport { cn, downloadJson } from \"@/lib/utils\"\nimport { Badge } from \"@/components/ui/badge\"\nimport { Button } from \"@/components/ui/button\"\nimport { Input } from \"@/components/ui/input\"\nimport { toast } from \"@/hooks/use-toast\"\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuItem,\n  DropdownMenuTrigger,\n} from \"@/components/ui/dropdown-menu\"\nimport type { Collection, RequestItem, HttpMethod } from \"@/hooks/use-request-store\"\n\n// Pending delete confirmation state\ninterface PendingDelete {\n  label: string\n  onConfirm: () => void\n}\n\nconst methodColors: Record<HttpMethod, string> = {\n  GET: \"bg-emerald-500/20 text-emerald-600 border-emerald-500/30\",\n  POST: \"bg-blue-500/20 text-blue-600 border-blue-500/30\",\n  PUT: \"bg-amber-500/20 text-amber-600 border-amber-500/30\",\n  PATCH: \"bg-purple-500/20 text-purple-600 border-purple-500/30\",\n  DELETE: \"bg-red-500/20 text-red-600 border-red-500/30\",\n}\n\nconst methodBadgeColors: Record<HttpMethod, string> = {\n  GET: \"bg-emerald-500 text-white\",\n  POST: \"bg-blue-500 text-white\",\n  PUT: \"bg-amber-500 text-white\",\n  PATCH: \"bg-purple-500 text-white\",\n  DELETE: \"bg-red-500 text-white\",\n}\n\nconst collectionColors: Record<string, string> = {\n  emerald: \"bg-emerald-500\",\n  blue: \"bg-blue-500\",\n  amber: \"bg-amber-500\",\n  purple: \"bg-purple-500\",\n  red: \"bg-red-500\",\n  pink: \"bg-pink-500\",\n}\n\nconst collectionBorderColors: Record<string, string> = {\n  emerald: \"border-emerald-500/40\",\n  blue: \"border-blue-500/40\",\n  amber: \"border-amber-500/40\",\n  purple: \"border-purple-500/40\",\n  red: \"border-red-500/40\",\n  pink: \"border-pink-500/40\",\n}\n\nconst collectionIcons: Record<string, React.ReactNode> = {\n  lock: <Lock className=\"size-3 text-white\" />,\n  users: <Users className=\"size-3 text-white\" />,\n  package: <Package className=\"size-3 text-white\" />,\n}\n\ntype ViewMode = \"list\" | \"card\"\n\ninterface CollectionsPanelProps {\n  collections: Collection[]\n  onSelectRequest: (request: RequestItem) => void\n  onSelectAndSendRequest?: (request: RequestItem) => void\n  onRunCollection?: (collection: Collection) => void\n  onRunCollectionBackground?: (collection: Collection) => void\n  onAddCollection: (data?: unknown) => string\n  onDeleteCollection: (id: string) => void\n  onRenameCollection: (id: string, name: string) => void\n  onAddRequestToCollection: (collectionId: string, request?: unknown) => void\n  onRemoveRequestFromCollection: (collectionId: string, requestId: string) => void\n}\n\nexport function CollectionsPanel({\n  collections,\n  onSelectRequest,\n  onSelectAndSendRequest,\n  onRunCollection,\n  onRunCollectionBackground,\n  onAddCollection,\n  onDeleteCollection,\n  onRenameCollection,\n  onAddRequestToCollection,\n  onRemoveRequestFromCollection,\n}: CollectionsPanelProps) {\n  if (typeof window !== 'undefined') {\n    try { console.log('COLLECTIONS_PANEL render: props.collections.length=', collections.length) } catch { // intentionally empty }\n  }\n  const [expandedCollections, setExpandedCollections] = useState<Set<string>>(\n    new Set(collections.map((c) => c.id))\n  )\n  const [editingCollectionId, setEditingCollectionId] = useState<string | null>(null)\n  const [renameValue, setRenameValue] = useState(\"\")\n  const [searchQuery, setSearchQuery] = useState(\"\")\n  const [viewMode, setViewMode] = useState<ViewMode>(\"list\")\n  const [pendingDelete, setPendingDelete] = useState<PendingDelete | null>(null)\n  const [collectionDetail, setCollectionDetail] = useState<Collection | null>(null)\n  const fileInputRef = useRef<HTMLInputElement>(null)\n\n  const handleImport = async (e: React.ChangeEvent<HTMLInputElement>) => {\n    const file = e.target.files?.[0]\n    if (!file) return\n\n    try {\n      const text = await file.text()\n      const data = JSON.parse(text)\n    console.log('DEBUG: imported file parsed', data)\n      \n      const processCollection = (colData: { name?: string; color?: string; icon?: string; requests?: unknown[] }) => {\n        console.log('DEBUG: processing collection', colData)\n        const colId = onAddCollection({\n          name: colData.name || \"Imported Collection\",\n          color: colData.color || \"emerald\",\n          icon: colData.icon || \"package\",\n        })\n        \n        if (colData.requests && Array.isArray(colData.requests)) {\n          colData.requests.forEach((req: unknown) => {\n            if (onAddRequestToCollection) {\n               onAddRequestToCollection(colId, req)\n            }\n          })\n        }\n      }\n\n      const dataObj = data as { type?: string; requests?: unknown[]; collections?: unknown[] };\n\n      if (dataObj.type === \"collection\" || dataObj.requests) {\n        processCollection(dataObj as Parameters<typeof processCollection>[0])\n        toast({ title: `Collection importв”ңвҢҗe`, meta: { event: \"importExport\" } } as unknown as Parameters<typeof toast>[0])\n        // (reverted) previously forced reload here; UI should update reactively\n      } else if (dataObj.collections && Array.isArray(dataObj.collections)) {\n        dataObj.collections.forEach((c) => processCollection(c as Parameters<typeof processCollection>[0]))\n        toast({ title: `${dataObj.collections.length} collections importв”ңвҢҗes`, meta: { event: \"importExport\" } } as unknown as Parameters<typeof toast>[0])\n        // (reverted) previously forced reload here; UI should update reactively\n      } else {\n         toast({ title: \"Format non reconnu\", variant: \"destructive\", meta: { event: \"importExport\" } } as unknown as Parameters<typeof toast>[0])\n      }\n      \n    } catch {\n      toast({ title: \"Fichier JSON invalide\", variant: \"destructive\", meta: { event: \"importExport\" } } as unknown as Parameters<typeof toast>[0])\n    }\n    \n    if (fileInputRef.current) {\n      fileInputRef.current.value = \"\"\n    }\n  }\n\n  const confirmDelete = (label: string, onConfirm: () => void) => {\n    setPendingDelete({ label, onConfirm })\n  }\n\n  // Selection state\n  const [selectedCollectionIds, setSelectedCollectionIds] = useState<Set<string>>(new Set())\n  const [selectedRequestIds, setSelectedRequestIds] = useState<Set<string>>(new Set()) // \"colId::reqId\"\n\n  const isSelecting = selectedCollectionIds.size > 0 || selectedRequestIds.size > 0\n\n  const toggleCollection = (id: string) => {\n    setExpandedCollections((prev) => {\n      const next = new Set(prev)\n      if (next.has(id)) next.delete(id)\n      else next.add(id)\n      return next\n    })\n  }\n\n  // --- Selection helpers ---\n  const toggleSelectCollection = (id: string) => {\n    setSelectedCollectionIds((prev) => {\n      const next = new Set(prev)\n      if (next.has(id)) next.delete(id)\n      else next.add(id)\n      return next\n    })\n  }\n\n  const toggleSelectRequest = (colId: string, reqId: string) => {\n    const key = `${colId}::${reqId}`\n    setSelectedRequestIds((prev) => {\n      const next = new Set(prev)\n      if (next.has(key)) next.delete(key)\n      else next.add(key)\n      return next\n    })\n  }\n\n  const clearSelection = () => {\n    setSelectedCollectionIds(new Set())\n    setSelectedRequestIds(new Set())\n  }\n\n  const selectAllCollections = () => {\n    setSelectedCollectionIds(new Set(filteredCollections.map((c) => c.id)))\n  }\n\n  // --- Bulk actions ---\n  const bulkExport = async () => {\n    const isTauri = !!(window as unknown as Record<string, unknown>).__TAURI_INTERNALS__ || !!(window as unknown as Record<string, unknown>).__TAURI__\n\n    // Gather selected collections\n    const cols = collections.filter((c) => selectedCollectionIds.has(c.id))\n\n    // Gather selected requests (grouped by collection)\n    const reqsByCol: Record<string, RequestItem[]> = {}\n    selectedRequestIds.forEach((key) => {\n      const [colId, reqId] = key.split(\"::\")\n      const col = collections.find((c) => c.id === colId)\n      const req = col?.requests.find((r) => r.id === reqId)\n      if (req) {\n        if (!reqsByCol[colId]) reqsByCol[colId] = []\n        reqsByCol[colId].push(req)\n      }\n    })\n\n    const exportData = {\n      exportedAt: new Date().toISOString(),\n      collections: [\n        ...cols,\n        ...Object.entries(reqsByCol)\n          .filter(([colId]) => !selectedCollectionIds.has(colId))\n          .map(([colId, reqs]) => {\n            const col = collections.find((c) => c.id === colId)!\n            return { ...col, requests: reqs }\n          }),\n      ],\n    }\n\n    const defaultName = cols.length === 1 && selectedRequestIds.size === 0\n      ? `${cols[0].name.replace(/\\s+/g, \"_\").toLowerCase()}_collection.json`\n      : \"export_selection.json\"\n\n    if (isTauri) {\n      try {\n        const { invoke } = await import(\"@tauri-apps/api/core\")\n        const savedPath = await invoke<string>(\"export_json\", {\n          content: JSON.stringify(exportData, null, 2),\n          defaultName,\n        })\n        toast({ title: `Exportв”ңвҢҗ : ${savedPath}`, meta: { event: \"importExport\" } } as unknown as Parameters<typeof toast>[0])\n        clearSelection()\n      } catch (error: unknown) {\n        if (error === \"cancelled\") return\n        toast({ title: `Erreur export : ${String(error)}`, variant: \"destructive\", meta: { event: \"importExport\" } } as unknown as Parameters<typeof toast>[0])\n        downloadJson(exportData, defaultName)\n      }\n    } else {\n      downloadJson(exportData, defaultName)\n      toast({ title: \"Export tв”ңвҢҗlв”ңвҢҗchargв”ңвҢҗ\", meta: { event: \"importExport\" } } as unknown as Parameters<typeof toast>[0])\n      clearSelection()\n    }\n  }\n\n  const bulkDelete = () => {\n    const colCount = selectedCollectionIds.size\n    const reqCount = selectedRequestIds.size\n    const msg = [\n      colCount > 0 && `${colCount} collection(s)`,\n      reqCount > 0 && `${reqCount} requв”ңВ¬te(s)`,\n    ]\n      .filter(Boolean)\n      .join(\" et \")\n\n    confirmDelete(`Supprimer ${msg} ?`, () => {\n      selectedCollectionIds.forEach((id) => onDeleteCollection(id))\n      selectedRequestIds.forEach((key) => {\n        const [colId, reqId] = key.split(\"::\")\n        onRemoveRequestFromCollection(colId, reqId)\n      })\n      clearSelection()\n    })\n  }\n\n  // --- Single item export ---\n  const exportCollection = async (collection: Collection) => {\n    const isTauri = !!(window as unknown as Record<string, unknown>).__TAURI_INTERNALS__ || !!(window as unknown as Record<string, unknown>).__TAURI__\n    const exportData = {\n      name: collection.name,\n      description: collection.description,\n      requests: collection.requests,\n      exportedAt: new Date().toISOString(),\n      type: \"collection\",\n    }\n    const safeName = collection.name.replace(/\\s+/g, \"_\").toLowerCase()\n\n    if (isTauri) {\n      try {\n        const { invoke } = await import(\"@tauri-apps/api/core\")\n        const savedPath = await invoke<string>(\"export_json\", {\n          content: JSON.stringify(exportData, null, 2),\n          defaultName: `${safeName}_collection.json`,\n        })\n        toast({ title: `Sauvegardв”ңвҢҗ : ${savedPath}`, meta: { event: \"importExport\" } } as unknown as Parameters<typeof toast>[0])\n      } catch (error: unknown) {\n        if (error === \"cancelled\") return\n        toast({ title: `Erreur : ${String(error)}`, variant: \"destructive\", meta: { event: \"importExport\" } } as unknown as Parameters<typeof toast>[0])\n        downloadJson(exportData, `${safeName}_collection.json`)\n      }\n    } else {\n      downloadJson(exportData, `${safeName}_collection.json`)\n    }\n  }\n\n  const filteredCollections = collections\n    .map((collection) => ({\n      ...collection,\n      requests: collection.requests.filter(\n        (req) =>\n          (req.name ?? \"\").toLowerCase().includes(searchQuery.toLowerCase()) ||\n          (req.endpoint ?? \"\").toLowerCase().includes(searchQuery.toLowerCase())\n      ),\n    }))\n    .filter(\n      (collection) =>\n        searchQuery === \"\" ||\n        collection.requests.length > 0 ||\n        collection.name.toLowerCase().includes(searchQuery.toLowerCase())\n    )\n\n  if (typeof window !== 'undefined') {\n    try { \n      console.log('COLLECTIONS_PANEL: filteredCollections.length=', filteredCollections.length, 'names=', filteredCollections.map(c=>c.name)) \n    } catch { \n      // intentionally empty \n    }\n  }\n\n  // Post-render DOM check: run after React commits to verify text nodes exist\n  if (typeof window !== 'undefined') {\n    try {\n       \n      ;(function watchDOM() {\n        try {\n          const names = filteredCollections.map((c) => c.name)\n          const results = names.map((name) => {\n            try {\n              const found = Array.from(document.querySelectorAll('*')).some((el) => el.textContent && el.textContent.includes(name))\n              return { name, found }\n            } catch {\n              return { name, found: false }\n            }\n          })\n          console.log('COLLECTIONS_PANEL POST_RENDER check', JSON.stringify(results))\n        } catch {\n          // intentionally empty\n        }\n      })()\n    } catch {\n      // intentionally empty\n    }\n  }\n\n  const totalSelected = selectedCollectionIds.size + selectedRequestIds.size\n\n  return (\n    <div className=\"flex h-full flex-col\">\n      {/* Header */}\n      <div className=\"flex items-center justify-between border-b border-border px-4 py-3 shrink-0\">\n        <h3 className=\"text-sm font-semibold text-foreground\">Collections</h3>\n        <div className=\"flex items-center gap-1\">\n          {/* View toggle */}\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            onClick={() => setViewMode(\"list\")}\n            className={cn(\"h-7 w-7 p-0\", viewMode === \"list\" && \"bg-accent\")}\n            title=\"Vue liste\"\n          >\n            <List className=\"size-3.5\" />\n          </Button>\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            onClick={() => setViewMode(\"card\")}\n            className={cn(\"h-7 w-7 p-0\", viewMode === \"card\" && \"bg-accent\")}\n            title=\"Vue carte\"\n          >\n            <LayoutGrid className=\"size-3.5\" />\n          </Button>\n          <div className=\"mx-1 h-4 w-px bg-border\" />\n          <input \n            type=\"file\" \n            accept=\".json\" \n            ref={fileInputRef} \n            onChange={handleImport} \n            className=\"hidden\" \n          />\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            onClick={() => fileInputRef.current?.click()}\n            className=\"h-7 gap-1 px-2 text-xs\"\n            title=\"Importer JSON\"\n          >\n            <Import className=\"size-3.5\" />\n            Import\n          </Button>\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            onClick={onAddCollection}\n            className=\"h-7 gap-1 px-2 text-xs\"\n          >\n            <FolderPlus className=\"size-3.5\" />\n            New\n          </Button>\n        </div>\n      </div>\n\n      {/* Search */}\n      <div className=\"border-b border-border p-3 shrink-0\">\n        <div className=\"relative\">\n          <Search className=\"absolute left-2.5 top-1/2 size-3.5 -translate-y-1/2 text-muted-foreground\" />\n          <Input\n            placeholder=\"Search collections & requests...\"\n            value={searchQuery}\n            onChange={(e) => setSearchQuery(e.target.value)}\n            className=\"h-8 pl-8 text-sm\"\n          />\n        </div>\n      </div>\n\n      {/* Selection toolbar */}\n      {isSelecting && (\n        <div className=\"flex items-center gap-2 border-b border-border bg-accent/50 px-4 py-2 shrink-0 animate-in slide-in-from-top-2 duration-150\">\n          <CheckSquare className=\"size-4 text-primary shrink-0\" />\n          <span className=\"text-xs font-medium text-foreground flex-1\">\n            {totalSelected} sв”ңвҢҗlectionnв”ңвҢҗ(s)\n          </span>\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            className=\"h-7 gap-1 px-2 text-xs\"\n            onClick={selectAllCollections}\n          >\n            <Layers className=\"size-3\" />\n            Tout\n          </Button>\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            className=\"h-7 gap-1 px-2 text-xs text-primary\"\n            onClick={bulkExport}\n          >\n            <Download className=\"size-3\" />\n            Exporter\n          </Button>\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            className=\"h-7 gap-1 px-2 text-xs text-destructive hover:text-destructive\"\n            onClick={bulkDelete}\n          >\n            <Trash2 className=\"size-3\" />\n            Supprimer\n          </Button>\n          <Button\n            variant=\"ghost\"\n            size=\"sm\"\n            className=\"h-7 w-7 p-0\"\n            onClick={clearSelection}\n          >\n            <X className=\"size-3.5\" />\n          </Button>\n        </div>\n      )}\n\n      {/* Collections content */}\n      <div className=\"flex-1 overflow-y-auto hide-scrollbar p-2\">\n        {viewMode === \"list\" ? (\n          // О“Г¶ГҮО“Г¶ГҮ LIST VIEW О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n          <div className=\"space-y-1\">\n            {filteredCollections.map((collection) => {\n              const isExpanded = expandedCollections.has(collection.id)\n              const isSelected = selectedCollectionIds.has(collection.id)\n\n              return (\n                <div\n                  key={collection.id}\n                  className={cn(\n                    \"mb-1 rounded-lg border transition-colors\",\n                    isSelected\n                      ? \"border-primary/50 bg-primary/5\"\n                      : \"border-transparent\"\n                  )}\n                >\n                  {/* Collection row */}\n                  <div className=\"group flex items-center gap-2 rounded-lg px-2 py-1.5 hover:bg-accent\">\n                    {/* Checkbox */}\n                    <button\n                      onClick={() => toggleSelectCollection(collection.id)}\n                      className=\"shrink-0 text-muted-foreground hover:text-primary transition-colors\"\n                    >\n                      {isSelected ? (\n                        <CheckSquare className=\"size-4 text-primary\" />\n                      ) : (\n                        <Square className=\"size-4 opacity-40 group-hover:opacity-100\" />\n                      )}\n                    </button>\n\n                    <div\n                      role=\"button\"\n                      tabIndex={0}\n                      onClick={() => toggleCollection(collection.id)}\n                      onKeyDown={(e) => { if (e.key === \"Enter\" || e.key === \" \") { e.preventDefault(); toggleCollection(collection.id) } }}\n                      className=\"flex items-center gap-2 flex-1 min-w-0 cursor-pointer\"\n                    >\n                      {isExpanded ? (\n                        <ChevronDown className=\"size-3.5 text-muted-foreground shrink-0\" />\n                      ) : (\n                        <ChevronRight className=\"size-3.5 text-muted-foreground shrink-0\" />\n                      )}\n                      <span\n                        className={cn(\n                          \"flex size-5 shrink-0 items-center justify-center rounded\",\n                          collectionColors[collection.color]\n                        )}\n                      >\n                        {collectionIcons[collection.icon] || <Package className=\"size-3 text-white\" />}\n                      </span>\n\n                      {editingCollectionId === collection.id ? (\n                        <div className=\"flex w-full items-center gap-2\" onClick={(e) => e.stopPropagation()}>\n                          <Input\n                            value={renameValue}\n                            onChange={(e) => setRenameValue(e.target.value)}\n                            onKeyDown={(event) => {\n                              if (event.key === \"Enter\") {\n                                onRenameCollection(collection.id, renameValue.trim() || collection.name)\n                                setEditingCollectionId(null)\n                              }\n                              if (event.key === \"Escape\") setEditingCollectionId(null)\n                            }}\n                            autoFocus\n                            className=\"h-7 text-sm\"\n                          />\n                          <Button\n                            variant=\"ghost\"\n                            size=\"sm\"\n                            onClick={(e) => {\n                              e.stopPropagation()\n                              onRenameCollection(collection.id, renameValue.trim() || collection.name)\n                              setEditingCollectionId(null)\n                            }}\n                            className=\"h-7 px-2 text-xs\"\n                          >\n                            OK\n                          </Button>\n                        </div>\n                      ) : (\n                        <div className=\"flex items-center gap-1.5 min-w-0\">\n                          <span className=\"truncate text-sm font-medium text-foreground\">\n                            {collection.name}\n                          </span>\n                          <span className=\"shrink-0 text-xs text-muted-foreground\">\n                            ({collection.requests.length})\n                          </span>\n                        </div>\n                      )}\n                    </div>\n\n                    <DropdownMenu>\n                      <DropdownMenuTrigger asChild>\n                        <Button\n                          variant=\"ghost\"\n                          size=\"sm\"\n                          className=\"size-6 p-0 opacity-0 group-hover:opacity-100\"\n                        >\n                          <MoreHorizontal className=\"size-3.5\" />\n                        </Button>\n                      </DropdownMenuTrigger>\n                      <DropdownMenuContent align=\"end\" className=\"w-44\">\n                        <DropdownMenuItem onClick={() => onAddRequestToCollection(collection.id)}>\n                          <Plus className=\"mr-2 size-3.5\" /> Add Request\n                        </DropdownMenuItem>\n                        {onRunCollection && (\n                          <DropdownMenuItem onClick={() => onRunCollection(collection)}>\n                            <Play className=\"mr-2 size-3.5\" /> Run collection\n                          </DropdownMenuItem>\n                        )}\n                        {onRunCollectionBackground && (\n                          <DropdownMenuItem onClick={() => onRunCollectionBackground(collection)}>\n                            <Play className=\"mr-2 size-3.5\" /> Run collection (background)\n                          </DropdownMenuItem>\n                        )}\n                        <DropdownMenuItem\n                          onClick={() => {\n                            setEditingCollectionId(collection.id)\n                            setRenameValue(collection.name)\n                          }}\n                        >\n                          <Edit2 className=\"mr-2 size-3.5\" /> Rename\n                        </DropdownMenuItem>\n                        <DropdownMenuItem onClick={() => exportCollection(collection)}>\n                          <Download className=\"mr-2 size-3.5\" /> Export JSON\n                        </DropdownMenuItem>\n                        <DropdownMenuItem\n                          onClick={() => onDeleteCollection(collection.id)}\n                          className=\"text-destructive\"\n                        >\n                          <Trash2 className=\"mr-2 size-3.5\" /> Delete\n                        </DropdownMenuItem>\n                      </DropdownMenuContent>\n                    </DropdownMenu>\n                  </div>\n\n                  {/* Requests */}\n                  {isExpanded && (\n                    <div className=\"ml-8 mt-0.5 space-y-0.5 border-l border-border pl-3 pb-1\">\n                      {collection.requests.map((request) => {\n                        const reqKey = `${collection.id}::${request.id}`\n                        const isReqSelected = selectedRequestIds.has(reqKey)\n                        return (\n                          <div\n                            key={request.id}\n                            className={cn(\n                              \"group flex w-full items-center gap-2 rounded-md px-2 py-1.5 transition-colors hover:bg-accent\",\n                              isReqSelected && \"bg-primary/5\"\n                            )}\n                          >\n                            {/* Request checkbox */}\n                            <button\n                              onClick={() => toggleSelectRequest(collection.id, request.id)}\n                              className=\"shrink-0 text-muted-foreground hover:text-primary transition-colors\"\n                            >\n                              {isReqSelected ? (\n                                <CheckSquare className=\"size-3.5 text-primary\" />\n                              ) : (\n                                <Square className=\"size-3.5 opacity-40 group-hover:opacity-100\" />\n                              )}\n                            </button>\n                            <button\n                              onClick={() => onSelectRequest(request)}\n                              className=\"flex flex-1 items-center gap-2 text-left min-w-0\"\n                            >\n                              <Badge\n                                variant=\"outline\"\n                                className={cn(\n                                  \"h-5 shrink-0 px-1.5 text-[10px] font-bold\",\n                                  methodColors[request.method]\n                                )}\n                              >\n                                {request.method}\n                              </Badge>\n                              <span className=\"truncate text-sm text-foreground\">{request.name}</span>\n                            </button>\n                            {onSelectAndSendRequest && (\n                              <Button\n                                variant=\"ghost\"\n                                size=\"sm\"\n                                onClick={() => onSelectAndSendRequest(request)}\n                                className=\"size-6 p-0 text-emerald-500 opacity-0 group-hover:opacity-100 hover:text-emerald-600 hover:bg-emerald-50\"\n                                title=\"Charger et exв”ңвҢҗcuter\"\n                              >\n                                <Play className=\"size-3\" />\n                              </Button>\n                            )}\n                            <Button\n                              variant=\"ghost\"\n                              size=\"sm\"\n                              onClick={() =>\n                                confirmDelete(\n                                  `Retirer \"${request.name}\" de \"${collection.name}\" ?`,\n                                  () => onRemoveRequestFromCollection(collection.id, request.id)\n                                )\n                              }\n                              className=\"size-6 p-0 text-destructive opacity-0 group-hover:opacity-100 hover:text-destructive\"\n                            >\n                              <Trash2 className=\"size-3\" />\n                            </Button>\n                          </div>\n                        )\n                      })}\n                      {collection.requests.length === 0 && (\n                        <p className=\"px-2 py-2 text-xs text-muted-foreground\">No requests yet</p>\n                      )}\n                    </div>\n                  )}\n                </div>\n              )\n            })}\n          </div>\n        ) : (\n          // О“Г¶ГҮО“Г¶ГҮ CARD VIEW О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\n          <div className=\"grid grid-cols-4 gap-2 p-1\">\n            {filteredCollections.map((collection) => {\n              const isSelected = selectedCollectionIds.has(collection.id)\n              return (\n                <div\n                  key={collection.id}\n                  className={cn(\n                    \"group relative flex flex-col items-center rounded-xl border p-3 transition-all cursor-default gap-2\",\n                    isSelected\n                      ? \"border-primary bg-primary/5 shadow-sm shadow-primary/20\"\n                      : cn(\"hover:border-border/80 hover:shadow-md\", collectionBorderColors[collection.color])\n                  )}\n                >\n                  {/* Checkbox */}\n                  <button\n                    onClick={() => toggleSelectCollection(collection.id)}\n                    className=\"absolute top-2 left-2 text-muted-foreground hover:text-primary transition-colors z-10\"\n                  >\n                    {isSelected ? (\n                      <CheckSquare className=\"size-3.5 text-primary\" />\n                    ) : (\n                      <Square className=\"size-3.5 opacity-0 group-hover:opacity-70\" />\n                    )}\n                  </button>\n\n                  {/* Menu */}\n                  <div className=\"absolute top-1.5 right-1.5 z-10\">\n                    <DropdownMenu>\n                      <DropdownMenuTrigger asChild>\n                        <Button variant=\"ghost\" size=\"sm\" className=\"size-5 p-0 opacity-0 group-hover:opacity-100\">\n                          <MoreHorizontal className=\"size-3\" />\n                        </Button>\n                      </DropdownMenuTrigger>\n                      <DropdownMenuContent align=\"end\" className=\"w-44\">\n                        <DropdownMenuItem onClick={() => onAddRequestToCollection(collection.id)}>\n                          <Plus className=\"mr-2 size-3.5\" /> Add Request\n                        </DropdownMenuItem>\n                        <DropdownMenuItem onClick={() => { setEditingCollectionId(collection.id); setRenameValue(collection.name) }}>\n                          <Edit2 className=\"mr-2 size-3.5\" /> Rename\n                        </DropdownMenuItem>\n                        <DropdownMenuItem onClick={() => exportCollection(collection)}>\n                          <Download className=\"mr-2 size-3.5\" /> Export JSON\n                        </DropdownMenuItem>\n                        <DropdownMenuItem onClick={() => confirmDelete(`Supprimer \"${collection.name}\" ?`, () => onDeleteCollection(collection.id))} className=\"text-destructive\">\n                          <Trash2 className=\"mr-2 size-3.5\" /> Delete\n                        </DropdownMenuItem>\n                      </DropdownMenuContent>\n                    </DropdownMenu>\n                  </div>\n\n                  {/* Clickable card body О“ГҘГҶ opens detail modal */}\n                  <button\n                    className=\"flex flex-col items-center gap-1.5 w-full pt-2\"\n                    onClick={() => setCollectionDetail(collection)}\n                  >\n                    <span className={cn(\"flex size-8 items-center justify-center rounded-lg\", collectionColors[collection.color])}>\n                      {collectionIcons[collection.icon] || <Package className=\"size-3.5 text-white\" />}\n                    </span>\n                    {editingCollectionId === collection.id ? (\n                      <div onClick={(e) => e.stopPropagation()} className=\"w-full\">\n                        <Input\n                          value={renameValue}\n                          onChange={(e) => setRenameValue(e.target.value)}\n                          onKeyDown={(ev) => {\n                            if (ev.key === \"Enter\") { onRenameCollection(collection.id, renameValue.trim() || collection.name); setEditingCollectionId(null) }\n                            if (ev.key === \"Escape\") setEditingCollectionId(null)\n                          }}\n                          autoFocus\n                          className=\"h-6 text-center text-xs\"\n                        />\n                      </div>\n                    ) : (\n                      <span className=\"text-center text-xs font-semibold text-foreground leading-tight line-clamp-2\">\n                        {collection.name}\n                      </span>\n                    )}\n                    <span className={cn(\"text-[10px] font-medium px-1.5 py-0.5 rounded-full\", collectionColors[collection.color], \"text-white opacity-90\")}>\n                      {collection.requests.length} req\n                    </span>\n                  </button>\n                </div>\n              )\n            })}\n          </div>\n        )}\n\n        {filteredCollections.length === 0 && (\n          <div className=\"flex flex-col items-center justify-center py-10 text-center\">\n            <Package className=\"size-8 text-muted-foreground/40\" />\n            <p className=\"mt-2 text-sm text-muted-foreground\">No collections found</p>\n          </div>\n        )}\n      </div>\n\n      {/* О“Г¶ГҮО“Г¶ГҮ Collection detail modal (card click) О“Г¶ГҮО“Г¶ГҮ */}\n      {collectionDetail && (\n        <AlertDialog open onOpenChange={(open) => !open && setCollectionDetail(null)}>\n          <AlertDialogContent className=\"max-w-md\">\n            <AlertDialogHeader>\n              <AlertDialogTitle className=\"flex items-center gap-2\">\n                <span className={cn(\"flex size-6 items-center justify-center rounded\", collectionColors[collectionDetail.color])}>\n                  {collectionIcons[collectionDetail.icon] || <Package className=\"size-3 text-white\" />}\n                </span>\n                {collectionDetail.name}\n                <span className=\"ml-auto text-xs font-normal text-muted-foreground\">\n                  {collectionDetail.requests.length} requв”ңВ¬te{collectionDetail.requests.length !== 1 ? \"s\" : \"\"}\n                </span>\n              </AlertDialogTitle>\n            </AlertDialogHeader>\n\n            <div className=\"max-h-72 overflow-y-auto space-y-1 py-1\">\n              {collectionDetail.requests.length === 0 && (\n                <p className=\"py-6 text-center text-sm text-muted-foreground\">Aucune requв”ңВ¬te dans cette collection.</p>\n              )}\n              {collectionDetail.requests.map((req) => {\n                const reqKey = `${collectionDetail.id}::${req.id}`\n                const isReqSelected = selectedRequestIds.has(reqKey)\n                return (\n                  <div\n                    key={req.id}\n                    className={cn(\n                      \"group flex items-center gap-2 rounded-lg px-3 py-2 transition-colors hover:bg-accent\",\n                      isReqSelected && \"bg-primary/5\"\n                    )}\n                  >\n                    <button onClick={() => toggleSelectRequest(collectionDetail.id, req.id)} className=\"shrink-0\">\n                      {isReqSelected\n                        ? <CheckSquare className=\"size-3.5 text-primary\" />\n                        : <Square className=\"size-3.5 text-muted-foreground opacity-40 group-hover:opacity-80\" />}\n                    </button>\n                    <button\n                      className=\"flex flex-1 items-center gap-2 min-w-0 text-left\"\n                      onClick={() => { onSelectRequest(req); setCollectionDetail(null) }}\n                    >\n                      <span className={cn(\"shrink-0 rounded px-1.5 py-0.5 text-[10px] font-bold text-white\", methodBadgeColors[req.method])}>\n                        {req.method}\n                      </span>\n                      <span className=\"truncate text-sm font-medium text-foreground\">{req.name}</span>\n                      <span className=\"ml-auto shrink-0 truncate text-xs text-muted-foreground max-w-[140px]\">{req.endpoint}</span>\n                    </button>\n                    {onSelectAndSendRequest && (\n                      <Button\n                        variant=\"ghost\" size=\"sm\"\n                        className=\"size-6 p-0 text-emerald-500 opacity-0 group-hover:opacity-100 hover:text-emerald-600 hover:bg-emerald-50\"\n                        title=\"Load & Send\"\n                        onClick={() => { onSelectAndSendRequest(req); setCollectionDetail(null) }}\n                      >\n                        <Play className=\"size-3\" />\n                      </Button>\n                    )}\n                    <Button\n                      variant=\"ghost\" size=\"sm\"\n                      className=\"size-6 p-0 text-destructive opacity-0 group-hover:opacity-100\"\n                      onClick={() => confirmDelete(\n                        `Retirer \"${req.name}\" de \"${collectionDetail.name}\" ?`,\n                        () => { onRemoveRequestFromCollection(collectionDetail.id, req.id); setCollectionDetail(null) }\n                      )}\n                    >\n                      <Trash2 className=\"size-3\" />\n                    </Button>\n                  </div>\n                )\n              })}\n            </div>\n\n            {(onRunCollection || onRunCollectionBackground) && (\n              <div className=\"flex flex-col gap-2 border-t border-border px-4 py-3\">\n                <div className=\"text-xs text-muted-foreground\">Exв”ңвҢҗcuter toutes les requв”ңВ¬tes de cette collection.</div>\n                <div className=\"flex flex-wrap gap-2\">\n                  {onRunCollection && (\n                    <Button\n                      variant=\"secondary\"\n                      size=\"sm\"\n                      onClick={() => {\n                        onRunCollection(collectionDetail)\n                        setCollectionDetail(null)\n                      }}\n                    >\n                      Run collection\n                    </Button>\n                  )}\n                  {onRunCollectionBackground && (\n                    <Button\n                      variant=\"ghost\"\n                      size=\"sm\"\n                      onClick={() => {\n                        onRunCollectionBackground(collectionDetail)\n                        setCollectionDetail(null)\n                      }}\n                    >\n                      Run collection (background)\n                    </Button>\n                  )}\n                </div>\n              </div>\n            )}\n            <AlertDialogFooter>\n              <AlertDialogCancel>Fermer</AlertDialogCancel>\n            </AlertDialogFooter>\n          </AlertDialogContent>\n        </AlertDialog>\n      )}\n\n      {/* О“Г¶ГҮО“Г¶ГҮ Delete confirmation modal О“Г¶ГҮО“Г¶ГҮ */}\n      <AlertDialog open={!!pendingDelete} onOpenChange={(open) => !open && setPendingDelete(null)}>\n        <AlertDialogContent>\n          <AlertDialogHeader>\n            <AlertDialogTitle className=\"flex items-center gap-2\">\n              <Trash2 className=\"size-5 text-destructive\" />\n              Confirmer la suppression\n            </AlertDialogTitle>\n            <AlertDialogDescription>\n              {pendingDelete?.label}\n              <br />\n              <span className=\"font-medium text-foreground\">Cette action est irrв”ңвҢҗversible.</span>\n            </AlertDialogDescription>\n          </AlertDialogHeader>\n          <AlertDialogFooter>\n            <AlertDialogCancel>Annuler</AlertDialogCancel>\n            <AlertDialogAction\n              className=\"bg-destructive text-destructive-foreground hover:bg-destructive/90\"\n              onClick={() => {\n                pendingDelete?.onConfirm()\n                setPendingDelete(null)\n              }}\n            >\n              Supprimer\n            </AlertDialogAction>\n          </AlertDialogFooter>\n        </AlertDialogContent>\n      </AlertDialog>\n    </div>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\empty-placeholder.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\environment-selector.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'updateEnvironment' is assigned a value but never used.","line":25,"column":84,"messageId":"unusedVar","endLine":25,"endColumn":101},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'deleteEnvironment' is assigned a value but never used.","line":25,"column":103,"messageId":"unusedVar","endLine":25,"endColumn":120}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\"\n\nimport { useState } from \"react\"\nimport { Check, ChevronsUpDown, Plus, Settings2, Trash2 } from \"lucide-react\"\nimport { cn } from \"@/lib/utils\"\nimport { useRequestStore, type EnvironmentVariable } from \"@/hooks/use-request-store\"\nimport { Button } from \"@/components/ui/button\"\nimport { Input } from \"@/components/ui/input\"\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuItem,\n  DropdownMenuLabel,\n  DropdownMenuSeparator,\n  DropdownMenuTrigger,\n} from \"@/components/ui/dropdown-menu\"\nimport {\n  Dialog,\n  DialogContent,\n  DialogTitle,\n} from \"@/components/ui/dialog\"\nimport { Checkbox } from \"@/components/ui/checkbox\"\n\nexport function EnvironmentSelector() {\n  const { environments, activeEnvironmentId, setActiveEnvironment, addEnvironment, updateEnvironment, deleteEnvironment } = useRequestStore()\n  \n  const [isManageOpen, setIsManageOpen] = useState(false)\n  const [editingEnvId, setEditingEnvId] = useState<string | null>(null)\n  \n  // Find active env\n  const activeEnv = environments.find(e => e.id === activeEnvironmentId) || environments[0]\n\n  const handleCreateNew = () => {\n    const newId = addEnvironment({\n      name: \"New Environment\",\n      color: \"slate\",\n      variables: [{ key: \"BASE_URL\", value: \"http://localhost:3000\", enabled: true }]\n    })\n    setEditingEnvId(newId)\n    setIsManageOpen(true)\n  }\n\n  return (\n    <>\n      <DropdownMenu>\n        <DropdownMenuTrigger asChild>\n          <Button variant=\"outline\" size=\"sm\" className=\"h-8 gap-2 border-dashed font-normal\">\n            <div className={cn(\"size-2 rounded-full\", activeEnv ? `bg-${activeEnv.color}-500` : \"bg-slate-500\")} />\n            {activeEnv ? activeEnv.name : \"No Environment\"}\n            <ChevronsUpDown className=\"size-3 text-muted-foreground\" />\n          </Button>\n        </DropdownMenuTrigger>\n        <DropdownMenuContent align=\"end\" className=\"w-[200px]\">\n          <DropdownMenuLabel className=\"text-xs text-muted-foreground\">Environments</DropdownMenuLabel>\n          <DropdownMenuSeparator />\n          {environments.map((env) => (\n            <DropdownMenuItem\n              key={env.id}\n              onClick={() => setActiveEnvironment(env.id)}\n              className=\"flex items-center gap-2\"\n            >\n              <div className={cn(\"size-2 rounded-full\", `bg-${env.color}-500`)} />\n              <span className=\"flex-1 truncate\">{env.name}</span>\n              {activeEnvironmentId === env.id && <Check className=\"size-3.5 text-primary\" />}\n            </DropdownMenuItem>\n          ))}\n          <DropdownMenuSeparator />\n          <DropdownMenuItem onClick={() => setIsManageOpen(true)} className=\"gap-2\">\n            <Settings2 className=\"size-3.5\" />\n            Manage Environments\n          </DropdownMenuItem>\n          <DropdownMenuItem onClick={handleCreateNew} className=\"gap-2\">\n            <Plus className=\"size-3.5\" />\n            New Environment\n          </DropdownMenuItem>\n        </DropdownMenuContent>\n      </DropdownMenu>\n\n      <ManageEnvironmentsDialog \n        open={isManageOpen} \n        onOpenChange={setIsManageOpen} \n        initialEditingId={editingEnvId}\n      />\n    </>\n  )\n}\n\nfunction ManageEnvironmentsDialog({ open, onOpenChange, initialEditingId }: { open: boolean, onOpenChange: (open: boolean) => void, initialEditingId: string | null }) {\n  const { environments, addEnvironment, updateEnvironment, deleteEnvironment } = useRequestStore()\n  const [selectedId, setSelectedId] = useState<string | null>(initialEditingId || (environments.length > 0 ? environments[0].id : null))\n\n  // Update selected if initial changes or if deleted\n  if (open && initialEditingId && initialEditingId !== selectedId) {\n    setSelectedId(initialEditingId)\n  }\n\n  const selectedEnv = environments.find(e => e.id === selectedId)\n\n  const handleAddVar = () => {\n    if (!selectedEnv) return\n    updateEnvironment(selectedEnv.id, {\n      variables: [...selectedEnv.variables, { key: \"\", value: \"\", enabled: true }]\n    })\n  }\n\n  const updateVar = (index: number, field: keyof EnvironmentVariable, value: string | boolean) => {\n    if (!selectedEnv) return\n    const newVars = [...selectedEnv.variables]\n    newVars[index] = { ...newVars[index], [field]: value }\n    updateEnvironment(selectedEnv.id, { variables: newVars })\n  }\n\n  const removeVar = (index: number) => {\n    if (!selectedEnv) return\n    const newVars = [...selectedEnv.variables]\n    newVars.splice(index, 1)\n    updateEnvironment(selectedEnv.id, { variables: newVars })\n  }\n\n  return (\n    <Dialog open={open} onOpenChange={onOpenChange}>\n      <DialogContent className=\"max-w-4xl h-[80vh] p-0 gap-0 flex overflow-hidden\">\n        <DialogTitle className=\"sr-only\">Manage Environments</DialogTitle>\n        {/* Left Sidebar */}\n        <div className=\"w-1/3 border-r bg-muted/20 flex flex-col\">\n          <div className=\"p-4 border-b flex items-center justify-between\">\n            <h3 className=\"font-semibold text-sm\">Environments</h3>\n            <Button variant=\"ghost\" size=\"icon\" className=\"h-6 w-6\" onClick={() => {\n               const newId = addEnvironment({\n                name: \"New Environment\",\n                color: \"slate\",\n                variables: []\n              })\n              setSelectedId(newId)\n            }}>\n              <Plus className=\"size-4\" />\n            </Button>\n          </div>\n          <div className=\"flex-1 overflow-y-auto p-2 space-y-1\">\n            {environments.map(env => (\n              <button\n                key={env.id}\n                onClick={() => setSelectedId(env.id)}\n                className={cn(\n                  \"w-full flex items-center gap-2 px-3 py-2 rounded-md text-sm text-left transition-colors\",\n                  selectedId === env.id ? \"bg-accent text-accent-foreground\" : \"hover:bg-muted\"\n                )}\n              >\n                <div className={cn(\"size-2 rounded-full shrink-0\", `bg-${env.color}-500`)} />\n                <span className=\"truncate flex-1\">{env.name}</span>\n              </button>\n            ))}\n          </div>\n        </div>\n\n        {/* Right Content */}\n        <div className=\"flex-1 flex flex-col bg-background\">\n          {selectedEnv ? (\n            <>\n              <div className=\"p-4 border-b flex items-center gap-4\">\n                <Input \n                  value={selectedEnv.name}\n                  onChange={(e) => updateEnvironment(selectedEnv.id, { name: e.target.value })}\n                  className=\"max-w-[300px] font-semibold text-lg h-9 border-transparent hover:border-border focus-visible:border-border px-2\"\n                />\n                <Button \n                  variant=\"ghost\" \n                  size=\"icon\" \n                  className=\"h-8 w-8 ml-auto text-destructive hover:text-destructive hover:bg-destructive/10\"\n                  onClick={() => {\n                    if (environments.length === 1) return // Don't delete last env\n                    deleteEnvironment(selectedEnv.id)\n                    setSelectedId(environments.find(e => e.id !== selectedEnv.id)?.id || null)\n                  }}\n                  disabled={environments.length <= 1}\n                >\n                  <Trash2 className=\"size-4\" />\n                </Button>\n              </div>\n\n              <div className=\"flex-1 overflow-y-auto p-4\">\n                <div className=\"space-y-4\">\n                  <div className=\"flex items-center justify-between\">\n                    <h4 className=\"text-sm font-medium\">Variables</h4>\n                    <Button variant=\"outline\" size=\"sm\" onClick={handleAddVar} className=\"h-7 text-xs\">\n                      <Plus className=\"size-3 mr-1\" /> Add Variable\n                    </Button>\n                  </div>\n                  \n                  <div className=\"border rounded-md divide-y\">\n                    <div className=\"grid grid-cols-[auto_1fr_1fr_auto] gap-2 p-2 bg-muted/50 text-xs font-medium text-muted-foreground\">\n                      <div className=\"w-6\" />\n                      <div>VARIABLE</div>\n                      <div>VALUE</div>\n                      <div className=\"w-8\" />\n                    </div>\n                    {selectedEnv.variables.length === 0 ? (\n                      <div className=\"p-8 text-center text-sm text-muted-foreground\">\n                        No variables defined.\n                      </div>\n                    ) : (\n                      selectedEnv.variables.map((v, i) => (\n                        <div key={i} className=\"grid grid-cols-[auto_1fr_1fr_auto] gap-2 p-2 items-center group\">\n                          <div className=\"w-6 flex justify-center\">\n                            <Checkbox \n                              checked={v.enabled} \n                              onCheckedChange={(c) => updateVar(i, \"enabled\", !!c)}\n                            />\n                          </div>\n                          <Input \n                            value={v.key} \n                            onChange={(e) => updateVar(i, \"key\", e.target.value)}\n                            placeholder=\"KEY\"\n                            className=\"h-8 font-mono text-xs\"\n                          />\n                          <Input \n                            value={v.value} \n                            onChange={(e) => updateVar(i, \"value\", e.target.value)}\n                            placeholder=\"value\"\n                            className=\"h-8 font-mono text-xs\"\n                          />\n                          <Button \n                            variant=\"ghost\" \n                            size=\"icon\" \n                            onClick={() => removeVar(i)}\n                            className=\"size-8 opacity-0 group-hover:opacity-100 text-destructive\"\n                          >\n                            <Trash2 className=\"size-3.5\" />\n                          </Button>\n                        </div>\n                      ))\n                    )}\n                  </div>\n                </div>\n              </div>\n            </>\n          ) : (\n            <div className=\"flex-1 flex items-center justify-center text-muted-foreground\">\n              Select an environment\n            </div>\n          )}\n        </div>\n      </DialogContent>\n    </Dialog>\n  )\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\floating-ai-chat.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\history-panel.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\components\\import-export-modal.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"mess