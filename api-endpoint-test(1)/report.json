tItem(\"sidebar-collapsed\")\n    if (stored) {\n      setIsCollapsed(JSON.parse(stored))\n    }\n  }, [])\n\n  // Close sidebar automatically on narrower desktop widths\n  useEffect(() => {\n    if (isNarrow) {\n      setIsCollapsed(true)\n    }\n  }, [isNarrow])\n\n  // Save to localStorage\n  useEffect(() => {\n    localStorage.setItem(\"sidebar-collapsed\", JSON.stringify(isCollapsed))\n  }, [isCollapsed])\n\n  const toggleSidebar = () => setIsCollapsed((prev) => !prev)\n  const collapseSidebar = () => setIsCollapsed(true)\n  const expandSidebar = () => setIsCollapsed(false)\n\n  return (\n    <SidebarContext.Provider value={{ isCollapsed, toggleSidebar, collapseSidebar, expandSidebar }}>\n      {children}\n    </SidebarContext.Provider>\n  )\n}\n\nexport function useSidebar() {\n  const context = useContext(SidebarContext)\n  if (!context) {\n    throw new Error(\"useSidebar must be used within a SidebarProvider\")\n  }\n  return context\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\eslint.config.mjs","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\hooks\\use-ai-context.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\hooks\\use-keyboard-shortcuts.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\rough\\Documents\\Workspace\\apiPlayground\\api-endpoint-test(1)\\hooks\\use-mobile.ts","messages":[{"ruleId":"react-hooks/set-state-in-effect","severit