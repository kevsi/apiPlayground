# ──────────────────────────────────────────────────────────────────────────
# Reqly environment variables
#
# Two separate .env.local files exist, both derived from .env.example:
#   - reqy-web/.env.local   — consumed by the Next.js app
#   - sync-server/.env.local — consumed by the standalone sync server
#
# Variables marked with a section header below tell you which file they
# belong to. NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────

# ── reqy-web (Next.js) ──────────────────────────────────────────────────
POSTMAN_CLIENT_ID=
POSTMAN_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── sync-server (Hono + SQLite) ─────────────────────────────────────────
# Port the sync server listens on. Defaults to 4000.
PORT=4000

# Comma-separated list of allowed origins for CORS. Use * to allow all
# (insecure — only use for local development).
ALLOWED_ORIGIN=http://localhost:3000

# ── Shared between reqy-web and sync-server ─────────────────────────────
# MUST be identical on both sides, otherwise auth cookies won't validate.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters (validated at boot).
AUTH_SIGNING_SECRET=replace_me_with_a_random_64_char_hex_string

# URL of the sync server, exposed to the browser. Used by reqy-web to
# open WebSocket connections and push/pull workspaces.
NEXT_PUBLIC_SYNC_URL=http://localhost:4000
