{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Reqly",
  "version": "0.1.0",
  "identifier": "com.reqly.app",
  "build": {
    "frontendDist": "../reqy-web/.next",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npx pnpm --dir ./reqy-web dev",
    "beforeBuildCommand": "npx pnpm --dir ./reqy-web build"
  },
  "app": {
    "windows": [
      {
        "title": "Reqly",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:*; img-src 'self' data:; font-src 'self'; form-action 'self'; frame-ancestors 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
